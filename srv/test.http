### GET all Employees
GET http://localhost:4004/odata/v4/employeeService/Employees

### get division
GET http://localhost:4004/odata/v4/employeeService/Divisions

### get departments
GET http://localhost:4004/odata/v4/employeeService/Departments


### POST Department
POST http://localhost:4004/odata/v4/employeeService/Departments
Content-Type: application/json

{
  "name": "React Developer",
  "division_ID": "11111111-1111-1111-1111-111111111111"
}

### POST employee
POST http://localhost:4004/odata/v4/employeeService/Employees
Content-Type: application/json

{
  "name": "rahul",
  "email": "rahul123@gmail.com",
  "phone":"+91-2222222222",
  "department_ID":"d1fd23df-0d75-4243-8b1a-4ab048346f67",
  "division_ID": "11111111-1111-1111-1111-111111111111",
  "address":{
  "city":"ramgarh",
  "state":"jharkhand"
  }
}

